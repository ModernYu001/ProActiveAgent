# 复制本文件为 .env 并填入你自己的密钥： cp .env.example .env
# .env 已被 .gitignore 忽略, 不会进仓库。切勿把真实密钥写进本模板文件。

# ===== LLM: Gemini (native API) =====
# 多个密钥用逗号分隔，系统会在密钥间轮训以分摊配额
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2

# ===== LLM: grok (OpenAI 兼容代理) =====
GROK_BASE_URL=http://your-grok-proxy:8000/v1
GROK_API_KEY=your_grok_api_key
GROK_MODEL=grok-4.20-fast
GROK_STREAM=true          # 该代理非流式返回空, 必须流式; 一般保持 true
GROK_MAX_ATTEMPTS=3       # 空响应自动重试次数(空响应不计配额)

# ===== GitHub (可选, 提高 trending 抓取的速率上限) =====
GITHUB_TOKEN=your_github_token

# ===== Tavily 搜索 API (新闻主力源) =====
TAVILY_API_KEY=your_tavily_api_key
TAVILY_MONTHLY_CREDITS=1000   # 你的月额度
TAVILY_BUDGET_RATIO=0.8       # 只用 80%, 到顶即停

# ===== 交付渠道: 邮件 (SMTP) =====
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_TO=your_email@gmail.com

# ===== 交付渠道: Telegram =====
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ===== 交付渠道: 网页 (生成静态 JSON+HTML, 供网站托管) =====
WEB_ENABLED=true
WEB_OUT_DIR=./web_out
